[m;\u001b[K\u001b[102C\r\n     }\u001b[114C\r\n \u001b[32m\u001b[1m### 4. C++\u001b[m\u001b[K\u001b[109C\r\n C++ is an extension of C and commonly uses the \u001b[33miostream \u001b[mlibrary and the \u001b[33mstd::cout \u001b[mobject for output.\u001b[K\u001b[19C\r\n     \u001b[90m#include <iostream>\u001b[K\u001b[96C\u001b[m\r\n\u001b[120C\r\n     \u001b[34mint \u001b[33mmain() \u001b[m{\u001b[K\u001b[103C\r\n         std::cout << \u001b[31m\"Hello, World!\" \u001b[m<< std::endl;\u001b[K\u001b[69C\r\n\u001b[34m\u001b[9Creturn \u001b[32m0\u001b[m;\u001b[K\u001b[102C\r\n     }\u001b[114C\r\n \u001b[1mSummary of differences:\u001b[22m\u001b[K\u001b[96C\r\n     * **Python & JS:** High-level, very concise, and don't require a formal \"main\" function structure to run a simple  \r\n script.\u001b[112C\r\n     * **C & C++:** Compiled languages that require a defined entry point (`int main()`) and explicit library imports   \r\n to handle printing to the screen.\u001b[86C\r\n\u001b[120C\r\n\u001b[120C\r\n\u001b[2m‚ē≠‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ēģ\u001b[22m\r\n\u001b[2m‚Ēā\u001b[36m\u001b[22m\u001b[1m > \u001b[mCould you write the Python \"Hello world!\" program into he\u001b[7m \u001b[27m\u001b[57X\u001b[2m\u001b[57C‚Ēā\u001b[?2026l"]
